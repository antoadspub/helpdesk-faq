<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_faq_tag_list" model="ir.ui.view">
        <field name="name">faq.tag.list</field>
        <field name="model">faq.tag</field>
        <field name="arch" type="xml">
            <list string="FAQ Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="question_count" string="Questions"/>
            </list>
        </field>
    </record>

    <record id="view_faq_tag_form" model="ir.ui.view">
        <field name="name">faq.tag.form</field>
        <field name="model">faq.tag</field>
        <field name="arch" type="xml">
            <form string="FAQ Tag">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Tag Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="color" widget="color_picker"/>
                        <field name="question_count" string="Questions" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_faq_tag" model="ir.actions.act_window">
        <field name="name">FAQ Tags</field>
        <field name="res_model">faq.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first FAQ tag!</p>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         FAQ Question — List View
    ============================================================ -->
    <record id="view_faq_question_list" model="ir.ui.view">
        <field name="name">faq.question.list</field>
        <field name="model">faq.question</field>
        <field name="arch" type="xml">
            <list string="FAQ"
                  decoration-muted="state == 'draft'"
                  decoration-success="state == 'published'">
                <field name="sequence" widget="handle"/>
                <field name="name" string="Question"/>
                <field name="category_id"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="helpful_count" string="👍"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'published'"
                    decoration-warning="state == 'draft'"/>
                <button
                    name="action_publish"
                    string="Publish"
                    type="object"
                    icon="fa-globe"
                    invisible="state == 'published'"
                    groups="helpdesk_faq.group_faq_manager"/>
                <button
                    name="action_unpublish"
                    string="Unpublish"
                    type="object"
                    icon="fa-eye-slash"
                    invisible="state == 'draft'"
                    groups="helpdesk_faq.group_faq_manager"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         FAQ Question — Form View
    ============================================================ -->
    <record id="view_faq_question_form" model="ir.ui.view">
        <field name="name">faq.question.form</field>
        <field name="model">faq.question</field>
        <field name="arch" type="xml">
            <form string="FAQ">
                <header>
                    <button
                        name="action_publish"
                        string="Publish"
                        type="object"
                        class="btn-primary"
                        invisible="state == 'published'"
                        groups="helpdesk_faq.group_faq_manager"/>
                    <button
                        name="action_unpublish"
                        string="Unpublish"
                        type="object"
                        invisible="state == 'draft'"
                        groups="helpdesk_faq.group_faq_manager"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,published"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <div class="oe_stat_button" style="cursor:default;">
                            <i class="fa fa-fw fa-thumbs-up o_button_icon"/>
                            <div class="o_stat_info">
                                <field name="helpful_count" class="o_stat_value"/>
                                <span class="o_stat_text">Helpful</span>
                            </div>
                        </div>
                        <div class="oe_stat_button" style="cursor:default;">
                            <i class="fa fa-fw fa-thumbs-down o_button_icon"/>
                            <div class="o_stat_info">
                                <field name="not_helpful_count" class="o_stat_value"/>
                                <span class="o_stat_text">Not Helpful</span>
                            </div>
                        </div>
                        <div class="oe_stat_button" style="cursor:default;">
                            <i class="fa fa-fw fa-paperclip o_button_icon"/>
                            <div class="o_stat_info">
                                <field name="attachment_count" class="o_stat_value"/>
                                <span class="o_stat_text">Attachments</span>
                            </div>
                        </div>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                placeholder="Type your question here..."
                                style="font-size: 1.4rem;"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"
                                options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Answer" name="answer">
                            <field name="answer"
                                widget="html"
                                placeholder="Write a detailed answer here..."
                                style="min-height: 200px;"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle me-1"/>
                                Maximum file size per attachment: <strong>2 MB</strong>.
                                Supported formats: PDF, Word, Excel, images, and more.
                            </div>
                            <field name="attachment_ids" widget="many2many_binary"
                                string="Attached Files"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         FAQ Question — Kanban View
    ============================================================ -->
    <record id="view_faq_question_kanban" model="ir.ui.view">
        <field name="name">faq.question.kanban</field>
        <field name="model">faq.question</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id"
                    class="o_kanban_small_col"
                    quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <field name="state"/>
                <field name="helpful_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div>
                                    <span t-if="record.state.raw_value == 'published'"
                                          class="badge text-bg-success">Published</span>
                                    <span t-else=""
                                          class="badge text-bg-warning">Draft</span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="text-muted" title="Helpful votes">
                                        👍 <field name="helpful_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         FAQ Question — Search View
    ============================================================ -->
    <record id="view_faq_question_search" model="ir.ui.view">
        <field name="name">faq.question.search</field>
        <field name="model">faq.question</field>
        <field name="arch" type="xml">
            <search string="Search FAQ">
                <field name="name" string="Question" filter_domain="[('name', 'ilike', self)]"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <!-- Filters -->
                <filter string="Published" name="published"
                        domain="[('state', '=', 'published')]"/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         FAQ Question — Actions
    ============================================================ -->
    <record id="action_faq_question" model="ir.actions.act_window">
        <field name="name">FAQ</field>
        <field name="res_model">faq.question</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_faq_question_search"/>
        <field name="context">{'search_default_published': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first FAQ question!
            </p>
            <p>
                Add questions and answers, assign a category,
                then publish them to make them visible on the website.
            </p>
        </field>
    </record>

    <record id="action_faq_question_published" model="ir.actions.act_window">
        <field name="name">Published FAQ</field>
        <field name="res_model">faq.question</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', '=', 'published')]</field>
        <field name="search_view_id" ref="view_faq_question_search"/>
    </record>

</odoo>

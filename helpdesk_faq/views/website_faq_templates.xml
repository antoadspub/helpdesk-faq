<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         FAQ Index Page  (/faq)
    ============================================================ -->
    <template id="website_faq_index" name="FAQ Index">
        <t t-call="website.layout">
            <div id="wrap" class="o_faq_wrap">

                <!-- Hero Banner -->
                <section class="o_faq_hero bg-light py-5 mb-4">
                    <div class="container text-center">
                        <h1 class="display-5 fw-bold">Frequently Asked Questions</h1>
                        <p class="lead text-muted">Find answers to the most common questions</p>

                        <!-- Search Bar -->
                        <form action="/faq" method="get" class="mt-4">
                            <div class="input-group mx-auto" style="max-width: 500px;">
                                <input
                                    type="text"
                                    name="search"
                                    class="form-control form-control-lg"
                                    placeholder="Search questions..."
                                    t-att-value="search"/>
                                <button class="btn btn-primary" type="submit">
                                    <i class="fa fa-search"/> Search
                                </button>
                            </div>
                        </form>
                    </div>
                </section>

                <div class="container pb-5">
                    <div class="row">

                        <!-- Sidebar: Categories -->
                        <div class="col-lg-3 mb-4">
                            <div class="card shadow-sm">
                                <div class="card-header bg-primary text-white fw-bold">
                                    <i class="fa fa-list"/> Categories
                                </div>
                                <div class="list-group list-group-flush">
                                    <a href="/faq"
                                       t-attf-class="list-group-item list-group-item-action #{not selected_category and 'active' or ''}">
                                        All Questions
                                    </a>
                                    <t t-foreach="categories" t-as="cat">
                                        <a t-attf-href="/faq?category_id=#{cat.id}"
                                           t-attf-class="list-group-item list-group-item-action d-flex justify-content-between align-items-center #{selected_category and selected_category.id == cat.id and 'active' or ''}">
                                            <t t-out="cat.name"/>
                                            <span class="badge bg-secondary rounded-pill">
                                                <t t-out="cat.published_question_count"/>
                                            </span>
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Main: Questions -->
                        <div class="col-lg-9">

                            <!-- Search Result Notice -->
                            <t t-if="search">
                                <div class="alert alert-info mb-3">
                                    <i class="fa fa-info-circle"/>
                                    Showing results for: <strong><t t-out="search"/></strong>
                                    <a href="/faq" class="ms-2 text-muted">(clear)</a>
                                </div>
                            </t>

                            <!-- No results -->
                            <t t-if="not questions">
                                <div class="text-center py-5 text-muted">
                                    <i class="fa fa-question-circle fa-3x mb-3"/>
                                    <p>No questions found. Try a different search term.</p>
                                </div>
                            </t>

                            <!-- Accordion FAQ List -->
                            <t t-if="questions">
                                <div class="accordion" id="faqAccordion">
                                    <t t-foreach="questions" t-as="q">
                                        <div class="accordion-item shadow-sm mb-2 border rounded">
                                            <h2 class="accordion-header" t-attf-id="heading_#{q.id}">
                                                <button
                                                    class="accordion-button collapsed fw-semibold"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    t-attf-data-bs-target="#collapse_#{q.id}"
                                                    aria-expanded="false"
                                                    t-attf-aria-controls="collapse_#{q.id}">
                                                    <t t-out="q.name"/>
                                                    <span class="ms-auto me-3 text-muted small">
                                                        <t t-out="q.category_id.name"/>
                                                    </span>
                                                </button>
                                            </h2>
                                            <div
                                                t-attf-id="collapse_#{q.id}"
                                                class="accordion-collapse collapse"
                                                t-attf-aria-labelledby="heading_#{q.id}"
                                                data-bs-parent="#faqAccordion">
                                                <div class="accordion-body">
                                                    <t t-out="q.answer"/>
                                                    <!-- Tags -->
                                                    <div class="mt-3" t-if="q.tag_ids">
                                                        <t t-foreach="q.tag_ids" t-as="tag">
                                                            <span class="badge bg-secondary me-1">
                                                                <t t-out="tag.name"/>
                                                            </span>
                                                        </t>
                                                    </div>
                                                    <!-- Helpful Vote -->
                                                    <div class="mt-3 pt-3 border-top d-flex align-items-center gap-3">
                                                        <small class="text-muted">Was this helpful?</small>
                                                        <button
                                                            class="btn btn-sm btn-outline-success faq-vote"
                                                            t-att-data-id="q.id"
                                                            data-helpful="1">
                                                            👍 Yes (<span class="vote-count"><t t-out="q.helpful_count"/></span>)
                                                        </button>
                                                        <button
                                                            class="btn btn-sm btn-outline-danger faq-vote"
                                                            t-att-data-id="q.id"
                                                            data-helpful="0">
                                                            👎 No (<span class="vote-count"><t t-out="q.not_helpful_count"/></span>)
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Vote JS -->
                <script>
                    document.querySelectorAll('.faq-vote').forEach(function(btn) {
                        btn.addEventListener('click', function() {
                            var questionId = this.dataset.id;
                            var helpful = this.dataset.helpful === '1';
                            fetch('/faq/' + questionId + '/vote', {
                                method: 'POST',
                                headers: {'Content-Type': 'application/json'},
                                body: JSON.stringify({
                                    jsonrpc: '2.0', method: 'call', id: 1,
                                    params: {helpful: helpful}
                                })
                            })
                            .then(r => r.json())
                            .then(data => {
                                if (data.result) {
                                    var spans = this.querySelectorAll('.vote-count');
                                    if (helpful) {
                                        this.querySelector('.vote-count').textContent = data.result.helpful_count;
                                    } else {
                                        this.querySelector('.vote-count').textContent = data.result.not_helpful_count;
                                    }
                                    this.disabled = true;
                                    this.classList.add('disabled');
                                }
                            });
                        });
                    });
                </script>

            </div>
        </t>
    </template>

    <!-- ============================================================
         FAQ Detail Page  (/faq/<id>)
    ============================================================ -->
    <template id="website_faq_detail" name="FAQ Detail">
        <t t-call="website.layout">
            <div id="wrap" class="o_faq_detail_wrap">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-8">

                            <!-- Breadcrumb -->
                            <nav aria-label="breadcrumb" class="mb-4">
                                <ol class="breadcrumb">
                                    <li class="breadcrumb-item"><a href="/faq">FAQ</a></li>
                                    <li class="breadcrumb-item">
                                        <a t-attf-href="/faq?category_id=#{question.category_id.id}">
                                            <t t-out="question.category_id.name"/>
                                        </a>
                                    </li>
                                    <li class="breadcrumb-item active" aria-current="page">
                                        <t t-out="question.name"/>
                                    </li>
                                </ol>
                            </nav>

                            <!-- Question Card -->
                            <div class="card shadow-sm">
                                <div class="card-header bg-primary text-white">
                                    <h4 class="mb-0"><t t-out="question.name"/></h4>
                                </div>
                                <div class="card-body">
                                    <t t-out="question.answer"/>

                                    <!-- Tags -->
                                    <div class="mt-4" t-if="question.tag_ids">
                                        <t t-foreach="question.tag_ids" t-as="tag">
                                            <span class="badge bg-secondary me-1">
                                                <t t-out="tag.name"/>
                                            </span>
                                        </t>
                                    </div>

                                    <!-- Helpful Vote -->
                                    <div class="mt-4 pt-3 border-top">
                                        <p class="fw-semibold">Was this answer helpful?</p>
                                        <button
                                            class="btn btn-outline-success me-2 faq-vote"
                                            t-att-data-id="question.id"
                                            data-helpful="1">
                                            👍 Yes (<t t-out="question.helpful_count"/>)
                                        </button>
                                        <button
                                            class="btn btn-outline-danger faq-vote"
                                            t-att-data-id="question.id"
                                            data-helpful="0">
                                            👎 No (<t t-out="question.not_helpful_count"/>)
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Related Questions -->
                            <div class="mt-5" t-if="related">
                                <h5 class="mb-3">Related Questions</h5>
                                <div class="list-group">
                                    <t t-foreach="related" t-as="rel">
                                        <a t-attf-href="/faq/#{rel.id}"
                                           class="list-group-item list-group-item-action">
                                            <i class="fa fa-angle-right me-2 text-primary"/>
                                            <t t-out="rel.name"/>
                                        </a>
                                    </t>
                                </div>
                            </div>

                            <div class="mt-4">
                                <a href="/faq" class="btn btn-outline-secondary">
                                    <i class="fa fa-arrow-left me-1"/> Back to FAQ
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>

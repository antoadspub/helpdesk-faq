<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         FAQ Category — List View
    ============================================================ -->
    <record id="view_faq_category_list" model="ir.ui.view">
        <field name="name">faq.category.list</field>
        <field name="model">faq.category</field>
        <field name="arch" type="xml">
            <list string="FAQ Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="question_count" string="Total Questions"/>
                <field name="published_question_count" string="Published"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         FAQ Category — Form View
    ============================================================ -->
    <record id="view_faq_category_form" model="ir.ui.view">
        <field name="name">faq.category.form</field>
        <field name="model">faq.category</field>
        <field name="arch" type="xml">
            <form string="FAQ Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_questions"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-question-circle">
                            <field name="question_count" string="Questions" widget="statinfo"/>
                        </button>
                        <button
                            name="action_view_questions"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-globe">
                            <field name="published_question_count" string="Published" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Short description of this category..."/>
                    </group>
                    <notebook>
                        <page string="Questions" name="questions">
                            <field name="question_ids" context="{'default_category_id': id}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="tag_ids" widget="many2many_tags"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'published'"
                                        decoration-warning="state == 'draft'"/>
                                    <field name="helpful_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         FAQ Category — Search View
    ============================================================ -->
    <record id="view_faq_category_search" model="ir.ui.view">
        <field name="name">faq.category.search</field>
        <field name="model">faq.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name"/>
                <field name="description"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Color" name="group_color" context="{'group_by': 'color'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         FAQ Category — Action
    ============================================================ -->
    <record id="action_faq_category" model="ir.actions.act_window">
        <field name="name">FAQ Categories</field>
        <field name="res_model">faq.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_faq_category_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first FAQ category!
            </p>
            <p>
                Organize your FAQ questions into logical categories
                like Billing, Technical, Shipping, etc.
            </p>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- FAQ User: read-only access to all FAQ content -->
        <record id="group_faq_user" model="res.groups">
            <field name="name">FAQ User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- FAQ Manager: full create / edit / publish / delete -->
        <record id="group_faq_manager" model="res.groups">
            <field name="name">FAQ Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_faq_user'))]"/>
        </record>

    </data>
</odoo>

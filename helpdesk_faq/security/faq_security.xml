<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================
             Security Category
        ============================================================ -->
        <record id="module_faq_category" model="ir.module.category">
            <field name="name">FAQ</field>
            <field name="description">Manage Frequently Asked Questions</field>
            <field name="sequence">100</field>
        </record>

        <!-- ============================================================
             Groups
        ============================================================ -->

        <!-- FAQ User: can read all FAQ content -->
        <record id="group_faq_user" model="res.groups">
            <field name="name">FAQ User</field>
            <field name="category_id" ref="module_faq_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view FAQs and categories.</field>
        </record>

        <!-- FAQ Manager: full control over FAQ content -->
        <record id="group_faq_manager" model="res.groups">
            <field name="name">FAQ Manager</field>
            <field name="category_id" ref="module_faq_category"/>
            <field name="implied_ids" eval="[(4, ref('group_faq_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Can create, edit, publish and delete FAQs.</field>
        </record>

    </data>
</odoo>
